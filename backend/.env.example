# --- Local (docker-compose) ---
DATABASE_URL=postgresql+asyncpg://capman:capman@db:5432/capman
REDIS_URL=redis://redis:6379/0

# --- Railway: DATABASE_URL, REDIS_URL, and PORT are auto-injected ---

# LLM APIs
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=the-pit
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
GENERATION_CACHE_ENABLED=true
GENERATION_CACHE_TTL_SECONDS=600
RAG_MAX_CHUNKS=3
RAG_MAX_CHUNK_CHARS=700
RAG_MAX_TOTAL_CHARS=2200

# Auth
JWT_SECRET_KEY=dev-secret-change-in-production

# App
APP_ENV=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
