  {
    "id": "greeks_call",
    "tool": "greeks_chart",
    "args": {"strike": 100, "time_to_expiry": 0.25, "volatility": 0.25, "risk_free_rate": 0.05, "option_type": "call"},
    "expected_chart_type": "multi_line",
    "expected_title_contains": "Call Option Greeks",
    "expected_keys": ["chart_type", "title", "x_label", "y_label", "series", "data"],
    "expected_data_length": 51,
    "expected_data_point_keys": ["price", "delta", "gamma", "theta", "vega"],
    "spot_checks": [
      {"field": "x_label", "equals": "Underlying Price"},
      {"field": "y_label", "equals": "Greek Value"}
    ],
    "data_assertions": [
      {"description": "Call delta between 0 and 1", "all_data_field": "delta", "range": [0.0, 1.0]},
      {"description": "Gamma non-negative", "all_data_field": "gamma", "range": [0.0, null]}
    ]
  },
