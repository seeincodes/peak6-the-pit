[
  {
    "id": "payoff_long_call",
    "tool": "option_payoff_chart",
    "args": {"strategy": "long_call", "strike": 100.0, "premium": 5.0},
    "expected_chart_type": "line",
    "expected_title_contains": "Long Call",
    "expected_keys": ["chart_type", "title", "x_label", "y_label", "zero_line", "series", "data"],
    "expected_data_length": 61,
    "expected_data_point_keys": ["price", "pnl"],
    "spot_checks": [
      {"field": "x_label", "equals": "Underlying Price"},
      {"field": "y_label", "equals": "Profit / Loss"},
      {"field": "zero_line", "equals": true}
    ],
    "data_assertions": [
      {"description": "At strike, payoff equals negative premium", "find_data_where": {"price": 100.0}, "expected_pnl": -5.0},
      {"description": "Deep OTM payoff equals negative premium", "find_data_where": {"price": 70.0}, "expected_pnl": -5.0},
      {"description": "Deep ITM payoff is positive", "find_data_where": {"price": 130.0}, "expected_pnl": 25.0}
    ]
  },
  {
