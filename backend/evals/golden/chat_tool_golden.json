    "expected_chart_type": "area",
    "expected_title_contains": "SPY Simulated Price History",
    "expected_keys": ["chart_type", "title", "x_label", "y_label", "series", "data"],
    "expected_data_length": 60,
    "expected_data_point_keys": ["day", "price"],
    "spot_checks": [
      {"field": "x_label", "equals": "Trading Day"},
      {"field": "y_label", "equals": "Price ($)"}
    ],
    "data_assertions": [
      {"description": "First day price equals start_price", "find_data_where": {"day": 1}, "expected_price": 100.0},
      {"description": "All prices positive", "all_data_field": "price", "range": [0.0, null]}
    ]
  }
