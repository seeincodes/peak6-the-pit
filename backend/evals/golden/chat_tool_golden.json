    "spot_checks": [],
    "data_assertions": [
      {"description": "Above strike payoff equals premium", "find_data_where": {"price": 65.0}, "expected_pnl": 3.0},
      {"description": "At strike payoff equals premium", "find_data_where": {"price": 50.0}, "expected_pnl": 3.0}
    ]
  },
